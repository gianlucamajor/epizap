profiles {    
    standard {
        docker.enabled = true
        
        process {
            container = 'gianlucamajor/epizap:latest'

            withLabel: few_cpu {
                cpus = 2
            }

            withLabel: med_cpu {
                cpus = 4
            }

            withLabel: many_cpu {
                cpus = 8
            }
        }
    }

    cluster {
        singularity.enabled = true

        process {
            executor = 'pbs'
            clusterOptions = {"-l nodes=1:ppn=${task.cpus},vmem=${task.memory.toGiga()}g"}
            container = '/home/gianluca/singularity/epizap.sif'

            withLabel: few_cpu {
                cpus = 4
                memory = 16.GB
            }

            withLabel: med_cpu {
                cpus = 8
                memory = 32.GB
            }

            withLabel: many_cpu {
                cpus = 32
                memory = 64.GB
                time = '5h'
            }
        }
    }
}
